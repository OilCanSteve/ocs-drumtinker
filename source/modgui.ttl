@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/OilCanSteve/ocs-drumtinker>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-oilcan-drumtinker.html> ;
        modgui:stylesheet <modgui/stylesheet-oilcan-drumtinker.css> ;
        modgui:javascript <modgui/drumtinker.js> ;
